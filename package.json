{
	"name": "ironflow-obsidian",
	"version": "1.0.0",
	"description": "Ironflow workflow definition tools for Obsidian Local REST API.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
		"generate:api-types": "npx openapi-typescript src/api/openapi.yaml -o src/api/schema.d.ts",
		"test": "tsc --noEmit --project tsconfig.test.json && vitest run",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [],
	"author": "Ironflow",
	"license": "MIT",
	"dependencies": {
		"yaml": "^2.8.1"
	},
	"devDependencies": {
		"@types/node": "^18.19.87",
		"@typescript-eslint/eslint-plugin": "5.29.0",
		"@typescript-eslint/parser": "5.29.0",
		"builtin-modules": "3.3.0",
		"esbuild": "^0.25.4",
		"obsidian": "latest",
		"obsidian-local-rest-api": "latest",
		"openapi-typescript": "^7.13.0",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"vitest": "^3.2.4"
	}
}
